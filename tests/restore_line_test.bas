1 REM Test RESTORE [line number]
2 REM RESTORE = first DATA; RESTORE 50 = first DATA at or after line 50
10 DATA 1,2,3
20 DATA 4,5,6
30 DATA 7,8,9
40 PRINT "Testing RESTORE..."
50 READ A,B,C
60 IF A=1 AND B=2 AND C=3 THEN PRINT "OK: first READ"
70 RESTORE 20
80 READ A,B,C
90 IF A=4 AND B=5 AND C=6 THEN PRINT "OK: RESTORE 20"
100 RESTORE 30
110 READ A,B,C
120 IF A=7 AND B=8 AND C=9 THEN PRINT "OK: RESTORE 30"
130 RESTORE
140 READ A,B,C
150 IF A=1 AND B=2 AND C=3 THEN PRINT "OK: RESTORE (no arg)"
160 RESTORE 15
170 READ A,B,C
180 IF A=4 AND B=5 AND C=6 THEN PRINT "OK: RESTORE 15 (first DATA >= 15)"
190 PRINT "RESTORE line test done."
200 END
