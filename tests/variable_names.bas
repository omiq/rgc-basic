10 REM Test variable names: SALE and SAFE must be distinct (full-name semantics)
20 SALE=100
30 SAFE=200
40 IF SALE<>100 THEN PRINT "FAIL: SALE expected 100": END
50 IF SAFE<>200 THEN PRINT "FAIL: SAFE expected 200": END
60 REM Long names
70 PLAYERSCORE=42
80 ENEMYHEALTH=99
90 IF PLAYERSCORE<>42 THEN PRINT "FAIL: PLAYERSCORE": END
100 IF ENEMYHEALTH<>99 THEN PRINT "FAIL: ENEMYHEALTH": END
110 REM String variables
120 FIRSTNAME$="ALICE"
130 LASTNAME$="SMITH"
140 IF FIRSTNAME$<>"ALICE" THEN PRINT "FAIL: FIRSTNAME$": END
150 IF LASTNAME$<>"SMITH" THEN PRINT "FAIL: LASTNAME$": END
160 PRINT "OK: variable names"
