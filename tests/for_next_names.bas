10 REM FOR/NEXT with longer variable names
20 FOR LOOPVAR=1 TO 3
30   TOTAL=TOTAL+LOOPVAR
40 NEXT LOOPVAR
50 IF TOTAL<>6 THEN PRINT "FAIL: TOTAL expected 6": END
60 FOR COUNTER=10 TO 12
70   SUM=SUM+COUNTER
80 NEXT COUNTER
90 IF SUM<>33 THEN PRINT "FAIL: SUM expected 33": END
100 PRINT "OK: FOR/NEXT names"
