REM Colour constants resolve to correct C64 palette indices (0-15)
IF BLACK <> 0 THEN PRINT "FAIL BLACK"
IF WHITE <> 1 THEN PRINT "FAIL WHITE"
IF RED <> 2 THEN PRINT "FAIL RED"
IF CYAN <> 3 THEN PRINT "FAIL CYAN"
IF PURPLE <> 4 THEN PRINT "FAIL PURPLE"
IF GREEN <> 5 THEN PRINT "FAIL GREEN"
IF BLUE <> 6 THEN PRINT "FAIL BLUE"
IF YELLOW <> 7 THEN PRINT "FAIL YELLOW"
IF ORANGE <> 8 THEN PRINT "FAIL ORANGE"
IF BROWN <> 9 THEN PRINT "FAIL BROWN"
IF PINK <> 10 THEN PRINT "FAIL PINK"
IF DARKGRAY <> 11 THEN PRINT "FAIL DARKGRAY"
IF DARKGREY <> 11 THEN PRINT "FAIL DARKGREY"
IF MEDGRAY <> 12 THEN PRINT "FAIL MEDGRAY"
IF LIGHTGREEN <> 13 THEN PRINT "FAIL LIGHTGREEN"
IF LIGHTBLUE <> 14 THEN PRINT "FAIL LIGHTBLUE"
IF LIGHTGRAY <> 15 THEN PRINT "FAIL LIGHTGRAY"
IF TRUE <> 1 THEN PRINT "FAIL TRUE"
IF FALSE <> 0 THEN PRINT "FAIL FALSE"
IF PI < 3.14 OR PI > 3.15 THEN PRINT "FAIL PI"
REM usable in expressions
IF RED + BLUE <> 8 THEN PRINT "FAIL RED+BLUE"
PRINT "OK"
