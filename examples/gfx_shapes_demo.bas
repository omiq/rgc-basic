1 REM =========================================================
2 REM gfx_shapes_demo — tour of every bitmap primitive
3 REM
4 REM PSET, LINE, RECT, FILLRECT, CIRCLE, FILLCIRCLE, ELLIPSE,
5 REM FILLELLIPSE, TRIANGLE, FILLTRIANGLE, DRAWTEXT — all in one
6 REM 320x200 frame. Cycles through a few colour tints by redrawing.
7 REM
8 REM Keys: Q quit
9 REM =========================================================
10 SCREEN 1
20 IF KEYDOWN(ASC("Q")) THEN END
30 CLS
40 REM --- row 1: outlines ---
50 RECT     8, 16 TO 56, 48
60 CIRCLE   88, 32, 16
70 ELLIPSE  136, 32, 24, 12
80 TRIANGLE 168, 48, 196, 16, 224, 48
90 LINE     240, 16 TO 280, 48
100 LINE    280, 16 TO 240, 48
110 FOR I = 240 TO 280 STEP 4 : PSET I, 32 : NEXT I
120 REM --- row 2: fills ---
130 FILLRECT     8, 72 TO 56, 104
140 FILLCIRCLE   88, 88, 16
150 FILLELLIPSE  136, 88, 24, 12
160 FILLTRIANGLE 168, 104, 196, 72, 224, 104
170 REM --- row 3: text with pixel placement ---
180 DRAWTEXT 8, 128, "PSET  LINE"
190 DRAWTEXT 8, 140, "RECT  FILLRECT"
200 DRAWTEXT 8, 152, "CIRCLE FILLCIRCLE"
210 DRAWTEXT 8, 164, "ELLIPSE FILLELLIPSE"
220 DRAWTEXT 8, 176, "TRIANGLE FILLTRIANGLE"
230 DRAWTEXT 8, 188, "DRAWTEXT  Q quit"
240 REM frame
250 RECT 0, 0 TO 319, 199
260 VSYNC
270 GOTO 20
