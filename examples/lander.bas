0 REM SPACE LANDER GAME (C64 BASIC)
10 POKE 53280,0:POKE 53281,0:CR$=CHR$(13)
15 RV$=CHR$(146)+CHR$(155):RO$=CHR$(146)+CHR$(144):SR=1024
20 PRINT CHR$(147)
30 PRINT CHR$(19);CHR$(5);SPC(13);CHR$(18)+"SPACE LANDER";CHR$(146)
40 PRINT CHR$(13);CHR$(159);SPC(6);"SPACE=THRUST O=LEFT P=RIGHT"
50 PRINT CHR$(13);CHR$(13);SPC(11);"CHOOSE DIFFICULTY:"
60 PRINT CHR$(13);CHR$(30);SPC(15);CHR$(18)+"1";CHR$(146)+" EASY"
70 PRINT CHR$(13);CHR$(158);SPC(15);CHR$(18)+"2";CHR$(146)+" MEDIUM"
80 PRINT CHR$(13);CHR$(150);SPC(15);CHR$(18)+"3";CHR$(146)+" HARD"
90 GOSUB 20000
100 GET C$:IF C$="" THEN GOTO 100
120 IF C$="1" THEN TS=0.75
130 IF C$="2" THEN TS=0.55
140 IF C$="3" THEN TS=0.45
150 IF VAL(C$)<=0 OR VAL(C$)>3 THEN GOTO 100
160 PRINT CHR$(147)
170 GY=20
180 GOSUB 570
190 X=20:Y=1:S=0.5:T=0:F=50:G=0.15
200 OX=X:OY=Y
210 GET C$: C$=UCASE$(C$): 
220 IF C$="P" AND X<39 THEN X=X+1
230 IF C$="O" AND X>0 THEN X=X-1
240 IF F>0 AND C$=" " AND T<(G*2) THEN T=T+0.25
250 S=S-T+G
260 IF S>1 THEN S=1
270 IF T>(G*2) THEN T=(G*2)
280 IF F>0 AND T>0 THEN F=F-1
290 IF T<=0 THEN T=0
300 IF T>0 THEN T=T-0.2
310 IF F=0 THEN T=0
320 Y=Y+S
330 IF Y<1 THEN Y=1
350 ?CHR$(19);CHR$(159);CHR$(18)+"FUEL";RV$,F
360 ?CHR$(159);CHR$(18)+"SPEED";RV$,LEFT$(STR$(S),3);" "
370 ?CHR$(159);CHR$(18)+"THRUST";RV$,LEFT$(STR$(ABS(T)),3);" ";RO$
375 CD=PEEK(1024+(INT(Y+1)*40)+X) : REM WHATS BELOW?
380 IF CD <> 32 AND CD <> 22 AND CD <> 88 THEN GOTO 610
385 GOSUB 500
390 SLEEP 12: GOTO 210
410 CD=PEEK(SR+(INT(Y+1)*40)+X)
420 IF INT(Y)>=GY THEN GOTO 610
430 IF CD<>32 AND CD<>22 AND CD<>88 THEN GOTO 610
440 GOTO 200
500 IF OX<>X OR OY<>Y THEN POKE SR+(INT(OY)*40)+OX,32:POKE SR+(INT(OY+1)*40)+OX,32
510 POKE SR+(INT(Y)*40)+X,88
520 IF C$=" " AND CD=32 THEN POKE SR+(INT(Y+1)*40)+X,22
530 OX=X:OY=Y
540 RETURN
570 FOR I=0 TO 39:OF=GY*40+I:POKE 55296+OF,9:POKE SR+OF,102:NEXT
580 RS=RND(-TI):PS=INT(RND(1)*34)+1:PE=PS+5
590 FOR I=PS TO PE:OF=GY*40+I:POKE 55296+OF,12:POKE SR+OF,247:NEXT
599 RETURN
610 PRINT:POKE SR+(INT(OY)*40)+OX,32:GOSUB 510
620 IF S>TS THEN GOTO 11000 
630 IF S<=TS THEN IF CD=247 THEN ?CR$;CHR$(5);"TOUCHDOWN!"
640 PRINT CHR$(5)+"PLAY AGAIN? Y/N";CHR$(144)
10000 GET C$
10010 IF C$="N" THEN END
10020 IF C$="Y" THEN 20
10030 GOTO 10000
11000 ? CR$;CHR$(150);"CRASH!":POKE SR+(INT(Y)*40)+X,42 :POKE SR+(INT(OY)*40)+X,42
11010 POKE SR+(INT(Y)*40)+X+1,42 :POKE SR+(INT(Y)*40)+X-1,42 
11100 GOTO 640
20000 REM
20110 RETURN
