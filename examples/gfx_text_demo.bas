1 REM GFX TEXT DEMO: PRINT/LOCATE/TEXTAT/CHR$/{TOKENS}/COLOR/BACKGROUND
2 REM Run with: ./basic-gfx -petscii examples/gfx_text_demo.bas
3 REM (In gfx mode, -petscii keeps token expansion enabled, but CHR$ stays raw.)
10 BACKGROUND 6
20 COLOR 14
30 PRINT "{CLR}{WHITE}CBM-BASIC GFX TEXT DEMO"
40 PRINT "{CYAN}PRINT + {YELLOW}TOKENS{CYAN} + {GREEN}COLOUR"
50 PRINT
60 COLOR 7
70 PRINT "THIS IS YELLOW VIA COLOR"
80 PRINT CHR$(28) "THIS IS RED VIA {RED} TOKEN CODE"
90 PRINT CHR$(146) "REVERSE OFF (FONT HAS INVERTED HALF)"
100 PRINT CHR$(18) "REVERSE ON" CHR$(146) "  (TOGGLE)"
110 COLOR 3
120 LOCATE 0,10
130 PRINT "LOCATE TO (0,10)"
140 TEXTAT 5,12,"TEXTAT(5,12): {LIGHT BLUE}HELLO"
150 TEXTAT 5,14,CHR$(159)+"CYAN VIA CHR$(159)"
160 COLOR 1
170 TEXTAT 0,22,"PRESS ESC TO CLOSE WINDOW (OR WAIT 5S)"
180 SLEEP 300
190 END

