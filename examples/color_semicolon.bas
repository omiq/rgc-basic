' Foreground COLOR demo
' COLOR n takes a C64-style palette index (0-15):
'   0=black  1=white  2=red  3=cyan  4=purple  5=green
'   6=blue   7=yellow 8=orange 9=brown 10=pink  11=dark-grey
'  12=grey  13=light-green 14=light-blue 15=light-grey

COLOR 2
PRINT "RED";
COLOR 1
PRINT " (back to white)"
