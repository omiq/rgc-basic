1 REM Hi-res bitmap: SCREEN 1, PSET/PRESET, POKE 8192+ (320x200, MSB=left)
2 REM Run: ./basic-gfx examples/gfx_bitmap_demo.bas
10 SCREEN 1
20 COLOR 1
30 BACKGROUND 6
40 FOR Y=0 TO 199
50 PSET 100,Y
60 NEXT Y
70 PSET 50,50
80 PRESET 50,50
85 LINE 20,100 TO 300,100
90 POKE 8192,255
100 POKE 8193,255
110 POKE 8232,255
120 POKE 8233,255
130 SLEEP 180
