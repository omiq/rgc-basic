diff --git a/src/raudio.c b/src/raudio.c
index 15859a6..d069a4e 100644
--- a/src/raudio.c
+++ b/src/raudio.c
@@ -178,6 +178,9 @@ typedef struct tagBITMAPINFOHEADER {
 #define MINIAUDIO_IMPLEMENTATION
 //#define MA_DEBUG_OUTPUT
 #include "external/miniaudio.h"         // Audio device initialization and management
+#ifdef __EMSCRIPTEN__
+#include <emscripten.h>
+#endif
 #undef PlaySound                        // Win32 API: windows.h > mmsystem.h defines PlaySound macro
 
 #include <stdlib.h>                     // Required for: malloc(), free()
@@ -1483,7 +1486,17 @@ Music LoadMusicStream(const char *fileName)
             music.ctxData = ctxMod;
             // NOTE: Only stereo is supported for MOD
             music.stream = LoadAudioStream(AUDIO.System.device.sampleRate, 16, AUDIO_DEVICE_CHANNELS);
-            music.frameCount = (unsigned int)jar_mod_max_samples(ctxMod);    // NOTE: Always 2 channels (stereo)
+            /* RGC-BASIC patch: upstream simulates the whole song in
+             * jar_mod_max_samples to compute frameCount — multi-second
+             * freeze under Emscripten + ASYNCIFY (web freeze triggers
+             * Chrome "page unresponsive") AND blocks LoadMusicStream for
+             * 10s+ on some Windows MinGW builds (user report 2026-04-20).
+             * Looping MOD playback doesn't need a real frame count:
+             * UpdateMusicStream modulos framesProcessed by frameCount and
+             * raylib's jar_mod wrapper handles loop boundaries internally.
+             * UINT_MAX makes the modulo effectively a no-op. See
+             * CHANGELOG.md "MOD load freeze fix (2026-04-20)". */
+            music.frameCount = 0xFFFFFFFFu;
             music.looping = true;   // Looping enabled by default
             musicLoaded = true;
         }
@@ -2077,8 +2090,13 @@ float GetMusicTimePlayed(Music music)
             int framesInFirstBuffer = music.stream.buffer->isSubBufferProcessed[0]? 0 : subBufferSize;
             int framesInSecondBuffer = music.stream.buffer->isSubBufferProcessed[1]? 0 : subBufferSize;
             int framesSentToMix = music.stream.buffer->frameCursorPos%subBufferSize;
-            int framesPlayed = (framesProcessed - framesInFirstBuffer - framesInSecondBuffer + framesSentToMix)%(int)music.frameCount;
-            if (framesPlayed < 0) framesPlayed += music.frameCount;
+            /* RGC-BASIC patch: MOD path uses frameCount = UINT_MAX (see
+             * LoadMusicStream hunk). Cast to int underflows to -1 and the
+             * modulo then clamps the result to 0 forever. Cap at INT_MAX
+             * so MOD streams return real elapsed time to MUSICTIME(). */
+            int modCount = (music.frameCount > 0 && music.frameCount < 0x80000000u) ? (int)music.frameCount : 0x7FFFFFFF;
+            int framesPlayed = (framesProcessed - framesInFirstBuffer - framesInSecondBuffer + framesSentToMix) % modCount;
+            if (framesPlayed < 0) framesPlayed += modCount;
             secondsPlayed = (float)framesPlayed/music.stream.sampleRate;
             ma_mutex_unlock(&AUDIO.System.lock);
         }
